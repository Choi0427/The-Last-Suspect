MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1825952102}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8810b84ddd02b3e46ac4440e363c1992, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::EvidenceInventoryUI
  popupRoot: {fileID: 151067445}
  hideOnStart: 1
  uiToHideWhileOpen:
  - {fileID: 1640340405}
  - {fileID: 1248769244}
  - {fileID: 1691980181}
  - {fileID: 811300998}
  - {fileID: 1717847425}
  - {fileID: 941941898}
  - {fileID: 1190756629}
  - {fileID: 457116505}
  evidenceNameText: {fileID: 1501961307}
  descriptionText: {fileID: 368757469}
  detailImage: {fileID: 1841963704}
  evidenceEntries:
  - evidenceName: Service Pistol
    description: "Service pistol in the victim\u2019s hand. Grip wear suggests a
      long-time user."
    thumbnail: {fileID: 21300000, guid: 64a88ee0887b96342bd8ee1faae7372d, type: 3}
    detailImage: {fileID: 21300000, guid: 64a88ee0887b96342bd8ee1faae7372d, type: 3}
  - evidenceName: Hair Sample
    description: "Black hair from the floor, male 40\u201350s. Heavy smoke and stress
      markers."
    thumbnail: {fileID: 21300000, guid: 5eb97d6a0934f9045af04b768a61c464, type: 3}
    detailImage: {fileID: 21300000, guid: 5eb97d6a0934f9045af04b768a61c464, type: 3}
  - evidenceName: Office Footprints
    description: "Sneaker prints near the door fit Adam\u2019s size. Deep inside,
      the same pattern repeats over many years."
    thumbnail: {fileID: 21300000, guid: 85df1657d41174a4a8376432f9a31bdb, type: 3}
    detailImage: {fileID: 21300000, guid: 85df1657d41174a4a8376432f9a31bdb, type: 3}
  - evidenceName: Blood Direction Pattern
    description: "Wiped blood lines point to the window, not the door. Shot angle
      proves it wasn\u2019t a normal desk suicide."
    thumbnail: {fileID: 21300000, guid: 9b1a4887f3d98e6498b9d0838e67cc0d, type: 3}
    detailImage: {fileID: 21300000, guid: 9b1a4887f3d98e6498b9d0838e67cc0d, type: 3}
  - evidenceName: Desk Fingerprint
    description: Clear fingerprint on the desk edge, high match with Martha. It sits
      on top of old dust.
    thumbnail: {fileID: 21300000, guid: 6e57110f2b6039344b46669a00272c55, type: 3}
    detailImage: {fileID: 21300000, guid: 6e57110f2b6039344b46669a00272c55, type: 3}
  - evidenceName: Indoor Cigarette Butt
    description: Cigarette butt inside the entrance, Tar aging shows it was smoked
      years before the crime.
    thumbnail: {fileID: 21300000, guid: f7ae51e57498e1b48b76d1934c6ee3a7, type: 3}
    detailImage: {fileID: 21300000, guid: f7ae51e57498e1b48b76d1934c6ee3a7, type: 3}
  - evidenceName: Printer Box Label
    description: "Torn label from Adam\u2019s print shop box near the desk. Timestamp:
      delivered the day before, opened from inside."
    thumbnail: {fileID: 21300000, guid: 8accb015de2718c47b71c6d2d23541f9, type: 3}
    detailImage: {fileID: 21300000, guid: 8accb015de2718c47b71c6d2d23541f9, type: 3}
