# This .gitignore file should be placed at the root of your Unity project directory
#
# Base reference:
# https://github.com/github/gitignore/blob/main/Unity.gitignore

############################
# Unity generated folders
############################
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# Memory / recordings
/[Mm]emoryCaptures/
/[Rr]ecordings/

############################
# IDE / editor files
############################
.vs/
.vscode/
.gradle/
.consulo/
.vsconfig

# Visual Studio / Rider / MonoDevelop generated files
ExportedObj/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.DotSettings.user

# Unity generated meta for IDE/debug files
*.pidb.meta
*.pdb.meta
*.mdb.meta

############################
# Crash / diagnostics
############################
sysinfo.txt
mono_crash.*
crashlytics-build.properties

############################
# Build outputs
############################
*.apk
*.aab
*.app
*.unitypackage
*.unitypackage.meta

############################
# Addressables / StreamingAssets
############################
/ServerData
/[Aa]ssets/[Ss]treamingAssets/aa*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml*
/[Aa]ssets/[Aa]ddressables_Temp*
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

############################
# Test / generated scenes
############################
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

############################
# Visual Scripting generated
############################
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

############################
# Optional Unity / Blender
############################
*.blend1
*.blend1.meta

# Uncomment if needed
# /[Aa]ssets/AssetStoreTools*

############################
# JetBrains Rider autogenerated plugin
############################
/[Aa]ssets/Plugins/Editor/JetBrains*

############################
# AR Foundation Remote related
############################
/ARFoundationRemoteCompanionApp/
/Assets/Plugins/ARFoundationRemoteInstaller/